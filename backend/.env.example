[Vault]
vault_path = ${OBSIDIAN_VAULT_PATH:/tmp/vibeflow/agent/demo-vault}

[LLM]
base_url = ${LLM_ENDPOINT_URL:http://localhost:8000/v1}
protocol = "openai-compatible"
model = ${LLM_MODEL:gpt-4o}
api_key_env = "LLM_API_KEY"

[Runner]
poll_interval_s = 2
max_concurrent_jobs = 1
job_timeout_s = 300

[Server]
host = "0.0.0.0"
port = 8080

[Oschertator]
system_prompt = "You are Oschertator, a 2nd Brain Assistant. You have access to the user's Obsidian vault. Use your tools to search and read notes, then provide helpful, concise answers."
